{
  "name": "Go Mega Power",

  "image": "mcr.microsoft.com/devcontainers/go:1-1.26",

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "golang.go-nightly",
        "ms-vscode.hexeditor",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "tamasfe.even-better-toml",
        "fill-labs.dependi",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker",
        "humao.rest-client",
        "ms-azuretools.vscode-docker"
      ],

      "settings": {
        "go.useLanguageServer": true,
        "go.formatTool": "gofumpt",
        "go.lintTool": "golangci-lint",

        "go.toolsManagement.checkForUpdates": "local",

        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },

        "editor.inlayHints.enabled": "on",

        "files.insertFinalNewline": true,

        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },


  "postCreateCommand": "bash .devcontainer/install-tools.sh",


  "postStartCommand": "echo '🚀 Go Mega Power Environment Ready' && go version && golangci-lint --version && air --version",


  "containerEnv": {
    "GO111MODULE": "on",
    "GOPROXY": "https://proxy.golang.org,direct",
    "GOSUMDB": "sum.golang.org",
    "CGO_ENABLED": "1"
  },


  "remoteUser": "vscode",

  "updateRemoteUserUID": true,


  "mounts": [
    "source=${localEnv:HOME}/go/pkg/mod,target=/go/pkg/mod,type=bind,consistency=cached"
  ],


  "forwardPorts": [
    8080,
    3000,
    5000,
    6379
  ],


  "portsAttributes": {
    "8080": {
      "label": "Go API"
    },
    "3000": {
      "label": "Frontend"
    }
  }
}
